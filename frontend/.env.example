# ── Backend API ────────────────────────────────────────
# Base URL of the Finvera backend (no trailing /api).
# When set, pages SSR their content from the backend.
# When empty, the site falls back to built-in mock data.

# Server-side (SSR) fetches:
API_URL=

# Client-side fetches (contact form). Usually the same value:
NEXT_PUBLIC_API_URL=

# ISR revalidation seconds for API data (default 60; 0 = always fresh)
API_REVALIDATE=60
