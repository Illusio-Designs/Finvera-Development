# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,https://www.finvera.solutions

# ── MySQL database ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finvera
DB_USER=root
DB_PASSWORD=
# Set to "true" to auto-create/update tables on boot (dev only)
DB_SYNC=true

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Seed admin (created on first run if missing) ───────
# These override the seed defaults (finverasolutionsllp@gmail.com / Rishi@1995).
# To change an ALREADY-created admin's password, also set ADMIN_RESET_PASSWORD=true
# once, restart, then remove the flag.
ADMIN_NAME=Finvera Admin
ADMIN_EMAIL=finverasolutionsllp@gmail.com
ADMIN_PASSWORD=Rishi@1995
# ADMIN_RESET_PASSWORD=true

# ── Uploads ────────────────────────────────────────────
# Public base URL of this API (used to build absolute image URLs)
PUBLIC_URL=http://localhost:5000
MAX_UPLOAD_MB=8
