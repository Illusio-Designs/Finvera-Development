# ── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,https://www.finvera.solutions

# ── MySQL database ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finvera
DB_USER=root
DB_PASSWORD=
# Set to "true" to auto-create/update tables on boot (dev only)
DB_SYNC=true

# ── Auth ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Seed admin (created on first run if missing) ───────
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@finvera.solutions
ADMIN_PASSWORD=changeme123

# ── Uploads ────────────────────────────────────────────
# Public base URL of this API (used to build absolute image URLs)
PUBLIC_URL=http://localhost:5000
MAX_UPLOAD_MB=8
